# ===========================================
# Supabase（必須）
# ===========================================
# https://supabase.com で無料プロジェクトを作成 → Project Settings → API から取得
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ===========================================
# サロンボード連携ドライバ: mock | csv | rpa | api
# 既定 (mock) は Supabase 内のテーブルにモック予約を書き込む
# ===========================================
SALONBOARD_DRIVER=mock

# RPA を使う場合（将来）
SALONBOARD_LOGIN_ID=
SALONBOARD_LOGIN_PASSWORD=

# 公式 API を得た場合（将来）
SALONBOARD_API_BASE_URL=
SALONBOARD_API_KEY=

# ===========================================
# LINE Messaging API（将来）
# ===========================================
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# ===========================================
# Instagram 投稿取得
# ===========================================
# ドライバ: mock | apify
# 未指定の場合: APIFY_API_TOKEN があれば apify、無ければ mock を自動選択
INSTAGRAM_FETCHER=

# Apify Instagram Scraper を使う場合（推奨・実投稿取得）:
# 1. https://apify.com でサインアップ
# 2. Settings → Integrations → API tokens → Create new token
# 3. ここに貼り付け
APIFY_API_TOKEN=
